{
  "name": "cropgraph",
  "version": "1.0.1",
  "description": "CropGraph CLI: USDA hardiness zones, frost dates, climate-aware planting plans, a 1000-crop calendar, and 333 companion relationships. All offline.",
  "keywords": [
    "cropgraph",
    "cli",
    "garden",
    "planting-calendar",
    "companion-planting",
    "usda-hardiness",
    "agriculture",
    "crops",
    "gardening"
  ],
  "author": "Andrew Christison",
  "license": "MIT",
  "homepage": "https://github.com/Cropgraph/cropgraph/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cropgraph/cropgraph",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Cropgraph/cropgraph/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cropgraph": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cropgraph/core": "workspace:^",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
