    "succession-planting",
    "pest-management",
    "usda-hardiness",
    "agriculture",
    "crop-calendar",
    "gardening",
    "plants",
    "permaculture"
  ],
  "author": "Andrew Christison",
  "license": "MIT",
  "homepage": "https://github.com/Cropgraph/cropgraph/tree/main/packages/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cropgraph/cropgraph",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/Cropgraph/cropgraph/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cropgraph-mcp": "dist/index.js"
